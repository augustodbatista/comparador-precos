{
  "name": "comparador-precos-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "ionic:serve": "vite --host 0.0.0.0",
    "ionic:build": "npm run build",
    "cap:init": "cap init \"Comparador de Preços\" br.com.jpcdo00.comparadorprecos --web-dir dist",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "android": "npm run build && cap sync android",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@ionic/react": "^8.8.12",
    "@ionic/react-router": "^8.8.12",
    "html5-qrcode": "2.3.8",
    "ionicons": "^8.0.13",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "4.3.1",
    "jsdom": "24.1.0",
    "typescript": "5.5.3",
    "vite": "5.3.4",
    "vitest": "2.0.5"
  }
}
